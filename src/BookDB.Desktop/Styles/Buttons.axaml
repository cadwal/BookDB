<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Disabled control overrides: replace Fluent gray-on-gray with readable contrast -->
    <Style Selector="Button:disabled">
        <Setter Property="Foreground" Value="{StaticResource BrushDisabledText}" />
        <Setter Property="Background" Value="{StaticResource BrushDisabledBackground}" />
    </Style>
    <Style Selector="TextBox:disabled">
        <Setter Property="Foreground" Value="{StaticResource BrushDisabledText}" />
        <Setter Property="Background" Value="{StaticResource BrushDisabledBackground}" />
    </Style>
    <Style Selector="ComboBox:disabled">
        <Setter Property="Foreground" Value="{StaticResource BrushDisabledText}" />
        <Setter Property="Background" Value="{StaticResource BrushDisabledBackground}" />
    </Style>
    <Style Selector="CheckBox:disabled">
        <Setter Property="Foreground" Value="{StaticResource BrushDisabledText}" />
        <Setter Property="Background" Value="{StaticResource BrushDisabledBackground}" />
    </Style>

    <!-- Icon button: transparent background, hover/active feedback, compact sizing -->
    <Style Selector="Button.iconButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Margin" Value="4,0" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="MinWidth" Value="0" />
    </Style>
    <Style Selector="Button.iconButton:disabled">
        <Setter Property="Foreground" Value="{StaticResource BrushDisabledText}" />
    </Style>
    <Style Selector="Button.iconButton:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource BrushIconHover}" />
    </Style>
    <Style Selector="Button.iconButton:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource BrushIconActive}" />
    </Style>

    <!-- Primary button: solid blue, white text, semibold -->
    <Style Selector="Button.primaryButton">
        <Setter Property="Background" Value="{StaticResource BrushPrimaryBlue}" />
        <Setter Property="Foreground" Value="{StaticResource BrushBadgeText}" />
        <Setter Property="Padding" Value="10,24" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="Button.primaryButton:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource BrushPrimaryBlueDark}" />
    </Style>

    <!-- Secondary button: bordered, transparent background -->
    <Style Selector="Button.secondaryButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorderInput}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
        <Setter Property="Padding" Value="10,24" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>
    <Style Selector="Button.secondaryButton:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#f5f5f5" />
    </Style>

    <!-- Toolbar separator: thin vertical divider between toolbar groups -->
    <Style Selector="Border.toolbarSeparator">
        <Setter Property="Width" Value="1" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Background" Value="{StaticResource BrushBorder}" />
        <Setter Property="Margin" Value="8,4" />
    </Style>
</Styles>
