<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Disabled control overrides: replace Fluent gray-on-gray with readable contrast.
         A button's disabled foreground is driven by Fluent's own resource key ButtonForegroundDisabled
         (its template-targeted disabled setter wins over an app-level style), so flavours recolor it by
         overriding that key — see High-contrast. -->
    <Style Selector="TextBox:disabled">
        <Setter Property="Foreground" Value="{DynamicResource BrushDisabledText}" />
        <Setter Property="Background" Value="{DynamicResource BrushDisabledBackground}" />
    </Style>
    <Style Selector="ComboBox:disabled">
        <Setter Property="Foreground" Value="{DynamicResource BrushDisabledText}" />
        <Setter Property="Background" Value="{DynamicResource BrushDisabledBackground}" />
    </Style>
    <Style Selector="CheckBox:disabled">
        <Setter Property="Foreground" Value="{DynamicResource BrushDisabledText}" />
        <Setter Property="Background" Value="{DynamicResource BrushDisabledBackground}" />
    </Style>

    <!-- Standard (unclassed) buttons follow the palette via DynamicResource so they stay legible in
         every flavour — Fluent's own button brushes don't react to our palette, which left them grey-on-grey
         in High contrast. The accent and custom button classes opt out and keep their own look. -->
    <Style Selector="Button:not(.accent):not(.iconButton):not(.primaryButton):not(.secondaryButton):not(.accentOutline):not(.helpLink):not(.link):not(.dangerButton)">
        <Setter Property="BorderBrush" Value="{DynamicResource BrushBorderInput}" />
        <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}" />
    </Style>

    <!-- Help link: hyperlink-styled button for contextual help (opens the Help window on a topic).
         Borderless accent text so it reads as a link, not an action; keyboard-focusable like any button. -->
    <Style Selector="Button.helpLink">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="2,1" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource BrushPrimaryBlue}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.helpLink:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource BrushPrimaryBlueDark}" />
    </Style>
    <Style Selector="Button.helpLink:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource BrushPrimaryBlueDark}" />
    </Style>

    <!-- Link: a borderless, transparent button that reads as an inline hyperlink (navigates rather than
         acting). Unlike helpLink it carries no help semantics and no fixed font size, so it inherits the
         surrounding text metrics. -->
    <Style Selector="Button.link">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource BrushPrimaryBlue}" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.link:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource BrushPrimaryBlueDark}" />
    </Style>
    <Style Selector="Button.link:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource BrushPrimaryBlueDark}" />
    </Style>

    <!-- Accent-outline button: highlights an important contextual action (e.g. Test connection, Check
         target) with the accent colour as a border + text, so it stands out from neutral buttons without
         the weight of the solid-accent primary action (Save/Move). When its command is unavailable it
         falls back to Fluent's neutral disabled look (transparent fill, grey text/border) — the same
         disabled appearance as every other button. -->
    <Style Selector="Button.accentOutline">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushPrimaryBlue}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource BrushPrimaryBlue}" />
    </Style>
    <Style Selector="Button.accentOutline:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BrushRowHover}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushPrimaryBlue}" />
        <Setter Property="Foreground" Value="{DynamicResource BrushPrimaryBlueDark}" />
    </Style>
    <Style Selector="Button.accentOutline:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BrushRowHover}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushPrimaryBlueDark}" />
        <Setter Property="Foreground" Value="{DynamicResource BrushPrimaryBlueDark}" />
    </Style>
    <!-- Disabled: drop the accent for the neutral grey outline used by the other buttons, so it still
         reads as a (disabled) button instead of floating grey text. Foreground stays Fluent's
         ButtonForegroundDisabled, matching every other disabled button. -->
    <Style Selector="Button.accentOutline:disabled /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushBorderInput}" />
    </Style>

    <!-- Danger button: solid error-red fill for destructive confirmations (Delete). Hover/pressed keep
         the error brush so the button never flashes back to the neutral Fluent grey mid-hover. -->
    <Style Selector="Button.dangerButton">
        <Setter Property="Background" Value="{DynamicResource BrushError}" />
        <Setter Property="Foreground" Value="{DynamicResource BrushBadgeText}" />
    </Style>
    <Style Selector="Button.dangerButton:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BrushError}" />
        <Setter Property="Foreground" Value="{DynamicResource BrushBadgeText}" />
    </Style>
    <Style Selector="Button.dangerButton:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BrushError}" />
        <Setter Property="Foreground" Value="{DynamicResource BrushBadgeText}" />
    </Style>

    <!-- Icon button: transparent background, hover/active feedback, compact sizing -->
    <Style Selector="Button.iconButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Margin" Value="4,0" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="MinWidth" Value="0" />
    </Style>
    <Style Selector="Button.iconButton:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BrushIconHover}" />
    </Style>
    <Style Selector="Button.iconButton:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BrushIconActive}" />
    </Style>

    <!-- Primary button: solid blue, white text, semibold. Padding is left to the theme default so the height
         matches the neutral/accent buttons it sits beside. -->
    <Style Selector="Button.primaryButton">
        <Setter Property="Background" Value="{DynamicResource BrushPrimaryBlue}" />
        <Setter Property="Foreground" Value="{DynamicResource BrushBadgeText}" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="Button.primaryButton:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BrushPrimaryBlueDark}" />
    </Style>

    <!-- Secondary button: bordered, transparent background. Padding is left to the theme default so the height
         matches the neutral/accent buttons it sits beside (an explicit tall padding made it look oversized). -->
    <Style Selector="Button.secondaryButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushBorderInput}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>
    <Style Selector="Button.secondaryButton:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BrushButtonHover}" />
    </Style>

    <!-- Toolbar separator: thin vertical divider between toolbar groups -->
    <Style Selector="Border.toolbarSeparator">
        <Setter Property="Width" Value="1" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Background" Value="{DynamicResource BrushBorder}" />
        <Setter Property="Margin" Value="8,4" />
    </Style>
</Styles>
