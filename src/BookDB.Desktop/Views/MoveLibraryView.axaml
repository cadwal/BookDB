<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BookDB.Desktop.ViewModels"
             xmlns:res="using:BookDB.Desktop.Localization"
             x:Class="BookDB.Desktop.Views.MoveLibraryView"
             x:DataType="vm:MoveLibraryViewModel">

  <UserControl.Styles>
    <Style Selector="TextBlock.error">
      <Setter Property="Foreground" Value="{DynamicResource SystemControlErrorTextForegroundBrush}"/>
    </Style>
  </UserControl.Styles>

  <!-- Wizard layout: the connection form is sized to its content (Auto, no dead space), the Move
       action bar is pinned, and the progress log (the only star row) absorbs all leftover height —
       so it grows when the window is enlarged and shrinks when it is reduced. The dialog MinHeight
       guarantees the form fits, so no scroll region is needed (matching the integrity tab). -->
  <Grid RowDefinitions="Auto,Auto,Auto,Auto,*">

    <!-- Header row lives outside the CanInteract gate so the help link stays usable during a move -->
    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="16,16,16,0">
      <TextBlock Text="{x:Static res:Resources.MoveLibrary_Intro}"
                 FontSize="12" Opacity="0.8" TextWrapping="Wrap" VerticalAlignment="Top"/>
      <Button Grid.Column="1" Classes="helpLink" VerticalAlignment="Top" Margin="12,0,0,0"
              Command="{Binding OpenRemoteDatabasesHelpCommand}">
        <TextBlock Text="{x:Static res:Resources.Help_RemoteDatabasesLink}" TextDecorations="Underline"/>
      </Button>
    </Grid>

    <StackPanel Grid.Row="1" Spacing="10" Margin="16,10,16,8" IsEnabled="{Binding CanInteract}">

      <!-- Source (read-only) -->
      <TextBlock Text="{x:Static res:Resources.MoveLibrary_SourceLabel}" FontSize="12" FontWeight="SemiBold"/>
      <TextBlock Text="{Binding SourceDescription}" FontSize="12" Margin="0,0,0,4"/>

      <!-- Target (the source is fixed; offer every backend that isn't the source) -->
      <TextBlock Text="{x:Static res:Resources.MoveLibrary_TargetLabel}" FontSize="12" FontWeight="SemiBold"/>
      <StackPanel Orientation="Horizontal" Spacing="16">
        <RadioButton GroupName="MoveTarget"
                     Content="{x:Static res:Resources.MoveLibrary_Target_Sqlite}"
                     IsChecked="{Binding TargetIsSqlite}"
                     IsVisible="{Binding ShowSqliteTargetOption}"/>
        <RadioButton GroupName="MoveTarget"
                     Content="{x:Static res:Resources.MoveLibrary_Target_Postgres}"
                     IsChecked="{Binding TargetIsPostgres}"
                     IsVisible="{Binding ShowPostgresTargetOption}"/>
        <RadioButton GroupName="MoveTarget"
                     Content="{x:Static res:Resources.MoveLibrary_Target_MySql}"
                     IsChecked="{Binding TargetIsMySql}"
                     IsVisible="{Binding ShowMySqlTargetOption}"/>
      </StackPanel>

      <!-- Server target editor (PostgreSQL or MySQL/MariaDB) -->
      <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
            IsVisible="{Binding IsServerTarget}">
        <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static res:Resources.Settings_Database_Host}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,8"/>
        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Host}" Margin="0,0,0,8"/>
        <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static res:Resources.Settings_Database_Port}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,8"/>
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Port}" Margin="0,0,0,8"/>
        <TextBlock Grid.Row="2" Grid.Column="0" Text="{x:Static res:Resources.Settings_Database_DatabaseName}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,8"/>
        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding DatabaseName}" Margin="0,0,0,8"/>
        <TextBlock Grid.Row="3" Grid.Column="0" Text="{x:Static res:Resources.Settings_Database_Username}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,8"/>
        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Username}" Margin="0,0,0,8"/>
        <TextBlock Grid.Row="4" Grid.Column="0" Text="{x:Static res:Resources.Settings_Database_Password}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,8"/>
        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Password}" PasswordChar="•" Margin="0,0,0,8"/>
        <TextBlock Grid.Row="5" Grid.Column="0" Text="{x:Static res:Resources.Settings_Database_TlsLabel}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
        <ComboBox Grid.Row="5" Grid.Column="1"
                  ItemsSource="{Binding AvailableSslModes}"
                  SelectedItem="{Binding SelectedSslMode}"
                  DisplayMemberBinding="{Binding DisplayName}"
                  HorizontalAlignment="Stretch"/>
      </Grid>

      </StackPanel>

    <!-- Pinned action bar: the validation steps and the primary Move action. -->
    <Border Grid.Row="2" Padding="16,10" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource BrushBorder}"
            IsEnabled="{Binding CanInteract}">
      <StackPanel Spacing="8">

        <!-- Validation buttons -->
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Content="{x:Static res:Resources.Settings_Database_TestConnection}" Command="{Binding TestConnectionCommand}" IsVisible="{Binding IsServerTarget}" Classes="accentOutline"/>
          <Button Content="{x:Static res:Resources.MoveLibrary_Check}" Command="{Binding CheckTargetCommand}" Classes="accentOutline"/>
          <TextBlock Text="{x:Static res:Resources.Settings_Database_Testing}" IsVisible="{Binding IsTesting}" VerticalAlignment="Center" FontSize="11" Opacity="0.7"/>
        </StackPanel>

        <!-- Validation results -->
        <TextBlock Text="{Binding TestResultMessage}" IsVisible="{Binding HasTestResult}" Classes.error="{Binding TestResultIsError}" FontSize="11" TextWrapping="Wrap"/>
        <TextBlock Text="{Binding CheckErrorMessage}" IsVisible="{Binding HasCheckError}" Classes="error" FontSize="11" TextWrapping="Wrap"/>
        <TextBlock Text="{x:Static res:Resources.MoveLibrary_Target_Empty}" IsVisible="{Binding TargetIsEmpty}" FontSize="11" Opacity="0.8"/>
        <StackPanel Spacing="4" IsVisible="{Binding TargetHasData}">
          <TextBlock Text="{Binding TargetHasDataWarning}" Classes="error" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap"/>
          <CheckBox Content="{x:Static res:Resources.MoveLibrary_Acknowledge}" IsChecked="{Binding AcknowledgeReplace}"/>
        </StackPanel>

        <!-- Failure -->
        <Border IsVisible="{Binding HasFailure}"
                BorderBrush="{DynamicResource SystemControlErrorTextForegroundBrush}"
                BorderThickness="1" CornerRadius="4" Padding="8">
          <TextBlock Text="{Binding FailureMessage}" Classes="error" FontSize="11" TextWrapping="Wrap"/>
        </Border>

        <!-- Switch active + primary Move action -->
        <Grid ColumnDefinitions="*,Auto">
          <CheckBox Grid.Column="0" Content="{x:Static res:Resources.MoveLibrary_SwitchActive}"
                    IsChecked="{Binding SwitchActiveWhenDone}" VerticalAlignment="Center"/>
          <Button Grid.Column="1" Content="{x:Static res:Resources.MoveLibrary_Move}"
                  Command="{Binding MoveCommand}" Classes="accent"/>
        </Grid>
      </StackPanel>
    </Border>

    <!-- Progress log (pinned below the action bar). No MinHeight: it shares the leftover space with
         the form via star sizing, so it grows when the window is enlarged and shrinks (never clips
         past the footer) when the window is small. -->
    <TextBlock Grid.Row="3" Text="{x:Static res:Resources.MoveLibrary_ProgressHeader}"
               FontSize="12" FontWeight="SemiBold" Margin="16,8,16,4"/>
    <Border Grid.Row="4" Margin="16,0,16,16"
            BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="4">
      <TextBox Text="{Binding LogText}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
               FontFamily="Consolas, monospace" FontSize="11" BorderThickness="0" Background="Transparent"
               ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto"/>
    </Border>

  </Grid>

</UserControl>
