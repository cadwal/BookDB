<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:BookDB.Desktop.ViewModels"
        xmlns:views="using:BookDB.Desktop.Views"
        xmlns:res="using:BookDB.Desktop.Localization"
        xmlns:behaviors="using:BookDB.Desktop.Behaviors"
        xmlns:i="using:Avalonia.Xaml.Interactivity"
        x:Class="BookDB.Desktop.Views.MaintenanceDialog"
        x:DataType="vm:MaintenanceViewModel"
        Title="{x:Static res:Resources.Maintenance_WindowTitle}"
        Width="680" MinWidth="520"
        Height="880" MinHeight="760"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        CanResize="True">

  <i:Interaction.Behaviors>
    <behaviors:LinearTabOrderBehavior />
  </i:Interaction.Behaviors>

  <DockPanel Margin="0">

    <!-- Title bar -->
    <Border DockPanel.Dock="Top"
            Background="{DynamicResource BrushBackgroundAlt}"
            Padding="16,12"
            BorderThickness="0,0,0,1"
            BorderBrush="{DynamicResource BrushBorder}">
      <TextBlock Text="{x:Static res:Resources.Maintenance_WindowTitle}" FontSize="14" FontWeight="SemiBold"/>
    </Border>

    <!-- Footer -->
    <Border DockPanel.Dock="Bottom"
            Padding="16,12"
            BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource BrushBorder}">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
        <Button Content="{x:Static res:Resources.Common_Close}"
                Command="{Binding CloseCommand}"
                IsEnabled="{Binding !IsRunning}"
                IsCancel="{Binding !IsRunning}"/>
      </StackPanel>
    </Border>

    <!-- Body: two tabs — database integrity and the cross-engine "Move library" migration. -->
    <TabControl Margin="8">

      <!-- Tab 1: Database integrity -->
      <TabItem Header="{x:Static res:Resources.Maintenance_IntegrityHeader}">
        <Grid Margin="8" RowDefinitions="Auto,Auto,*,Auto">
          <TextBlock Grid.Row="0"
                     Text="{x:Static res:Resources.Maintenance_Intro}"
                     FontSize="12" Opacity="0.8" TextWrapping="Wrap" Margin="0,0,0,12"/>

          <TextBlock Grid.Row="1"
                     Text="{x:Static res:Resources.Maintenance_ResultsHeader}"
                     FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>

          <Border Grid.Row="2"
                  BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="4">
            <TextBox Text="{Binding LogText}"
                     IsReadOnly="True" IsTabStop="False" AcceptsReturn="True" TextWrapping="Wrap"
                     FontFamily="Consolas, monospace" FontSize="11"
                     BorderThickness="0" Background="Transparent"
                     VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"/>
          </Border>

          <!-- Action buttons pinned at the bottom of the tab, consistent with the app's other dialogs. -->
          <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
            <Button Content="{x:Static res:Resources.Maintenance_RunCheck}" Command="{Binding RunCheckCommand}"/>
            <Button Content="{x:Static res:Resources.Maintenance_Repair}" Classes="accent" Command="{Binding OptimizeAndRepairCommand}"/>
          </StackPanel>
        </Grid>
      </TabItem>

      <!-- Tab 2: Move library (cross-engine migration) -->
      <TabItem Header="{x:Static res:Resources.MoveLibrary_Header}">
        <views:MoveLibraryView DataContext="{Binding MoveLibrary}"/>
      </TabItem>

    </TabControl>

  </DockPanel>

</Window>
