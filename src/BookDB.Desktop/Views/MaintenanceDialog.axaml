<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:BookDB.Desktop.ViewModels"
        xmlns:res="using:BookDB.Desktop.Localization"
        x:Class="BookDB.Desktop.Views.MaintenanceDialog"
        x:DataType="vm:MaintenanceViewModel"
        Title="{x:Static res:Resources.Maintenance_WindowTitle}"
        Width="560" MinWidth="480"
        Height="520" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        CanResize="True">

  <DockPanel Margin="0">

    <!-- Title bar -->
    <Border DockPanel.Dock="Top"
            Background="{DynamicResource BrushBackgroundAlt}"
            Padding="16,12"
            BorderThickness="0,0,0,1"
            BorderBrush="{DynamicResource BrushBorder}">
      <TextBlock Text="{x:Static res:Resources.Maintenance_WindowTitle}" FontSize="14" FontWeight="SemiBold"/>
    </Border>

    <!-- Footer -->
    <Border DockPanel.Dock="Bottom"
            Padding="16,12"
            BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource BrushBorder}">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
        <Button Content="{x:Static res:Resources.Maintenance_RunCheck}"
                Command="{Binding RunCheckCommand}"/>
        <Button Content="{x:Static res:Resources.Maintenance_Repair}"
                Classes="accent"
                Command="{Binding OptimizeAndRepairCommand}"/>
        <Button Content="{x:Static res:Resources.Common_Close}"
                Command="{Binding CloseCommand}"
                IsEnabled="{Binding !IsRunning}"/>
      </StackPanel>
    </Border>

    <!-- Body: sections stacked top-down; the results log fills the rest and grows on resize. -->
    <Grid Margin="16" RowDefinitions="Auto,Auto,Auto,*">

      <!-- Section 1: Database integrity -->
      <TextBlock Grid.Row="0"
                 Text="{x:Static res:Resources.Maintenance_IntegrityHeader}"
                 FontSize="13"
                 FontWeight="SemiBold"
                 Margin="0,0,0,4"/>
      <TextBlock Grid.Row="1"
                 Text="{x:Static res:Resources.Maintenance_Intro}"
                 FontSize="12"
                 Opacity="0.8"
                 TextWrapping="Wrap"
                 Margin="0,0,0,12"/>

      <!-- v2.0.0: a "Remote database" section (move the library to/from a remote DB) will be added here as a
           second section, above or below this results pane. The dialog shell is laid out to host it without
           rework. -->

      <TextBlock Grid.Row="2"
                 Text="{x:Static res:Resources.Maintenance_ResultsHeader}"
                 FontSize="12"
                 FontWeight="SemiBold"
                 Margin="0,0,0,4"/>

      <!-- Results / progress log: fills remaining space; wraps so long paths never widen the dialog. -->
      <Border Grid.Row="3"
              BorderBrush="{DynamicResource BrushBorder}"
              BorderThickness="1"
              CornerRadius="4">
        <TextBox Text="{Binding LogText}"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 FontFamily="Consolas, monospace"
                 FontSize="11"
                 BorderThickness="0"
                 Background="Transparent"
                 VerticalAlignment="Stretch"
                 HorizontalAlignment="Stretch"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
      </Border>

    </Grid>

  </DockPanel>

</Window>
