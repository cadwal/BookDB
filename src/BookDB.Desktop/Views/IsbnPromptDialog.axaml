<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:BookDB.Desktop.ViewModels"
        xmlns:res="using:BookDB.Desktop.Localization"
        x:Class="BookDB.Desktop.Views.IsbnPromptDialog"
        x:DataType="vm:IsbnPromptViewModel"
        Title="{x:Static res:Resources.Recatalog_NoIsbn_Title}"
        SizeToContent="WidthAndHeight"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Padding="24"
        MinWidth="340">
    <StackPanel Spacing="4">
        <TextBlock Text="{Binding Body}"
                   TextWrapping="Wrap" MaxWidth="340" />
        <TextBox Text="{Binding Isbn}"
                 PlaceholderText="{x:Static res:Resources.Recatalog_NoIsbn_Watermark}"
                 Width="280" Margin="0,8,0,0" HorizontalAlignment="Left" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
            <Button Content="{x:Static res:Resources.Recatalog_NoIsbn_LookUp}"
                    Classes="accent" IsDefault="True"
                    Command="{Binding LookUpCommand}" />
            <Button Content="{x:Static res:Resources.Common_Cancel}"
                    IsCancel="True"
                    Command="{Binding CancelCommand}" />
        </StackPanel>
    </StackPanel>
</Window>
