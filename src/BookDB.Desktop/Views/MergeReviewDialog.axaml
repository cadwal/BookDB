<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:BookDB.Desktop.ViewModels"
        xmlns:res="using:BookDB.Desktop.Localization"
        xmlns:conv="using:BookDB.Desktop.Converters"
        xmlns:views="using:BookDB.Desktop.Views"
        x:Class="BookDB.Desktop.Views.MergeReviewDialog"
        x:DataType="vm:MergeReviewViewModel"
        Title="{Binding WindowTitle}"
        Width="900"
        Height="620"
        MinWidth="700"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <DockPanel>
        <!-- Footer -->
        <Border DockPanel.Dock="Bottom" Margin="16,8,16,16">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8">
                <Button Content="{x:Static res:Resources.Common_Cancel}"
                        Command="{Binding CancelCommand}"
                        IsCancel="True" />
                <Button Content="{x:Static res:Resources.Common_SaveAndOpenEditor}"
                        Command="{Binding SaveAndOpenEditorCommand}" />
                <Button Content="{x:Static res:Resources.Common_Save}"
                        Classes="accent"
                        Command="{Binding SaveCommand}" />
            </StackPanel>
        </Border>

        <!-- Authors / collection stage — pinned below the scrolling diff grid:
             the picked Authors column seeds these rows; saved contributors come from them. -->
        <Border DockPanel.Dock="Bottom"
                Margin="16,0,16,0"
                Padding="0,8,0,0"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,1,0,0">
            <StackPanel Spacing="6">
                <TextBlock Text="{x:Static res:Resources.MergeReview_Authors_Label}"
                           FontWeight="SemiBold"
                           FontSize="12" />
                <TextBlock Text="{Binding AuthorsAgreementNote}"
                           IsVisible="{Binding HasAuthorsAgreementNote}"
                           FontSize="11"
                           Opacity="0.7"
                           TextWrapping="Wrap"
                           Margin="0,-2,0,0" />
                <ItemsControl ItemsSource="{Binding AuthorRows}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:PersonSuggestionRowViewModel">
                            <DockPanel LastChildFill="True" Margin="0,0,0,4">
                                <Button DockPanel.Dock="Right"
                                        Width="28" Height="28"
                                        Classes="iconButton"
                                        Content="×"
                                        AutomationProperties.Name="{x:Static res:Resources.MergeReview_RemoveAuthor}"
                                        Command="{Binding $parent[ItemsControl].((vm:MergeReviewViewModel)DataContext).RemoveAuthorRowCommand}"
                                        CommandParameter="{Binding}"
                                        Margin="4,0,0,0" />
                                <views:PersonSuggestionBox MinWidth="100" FontSize="13" MaxWidth="420" HorizontalAlignment="Left" />
                            </DockPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Button Content="{x:Static res:Resources.MergeReview_AddAuthor}"
                        Command="{Binding AddAuthorRowCommand}"
                        Classes="secondaryButton"
                        HorizontalAlignment="Left"
                        FontSize="13" />
                <DockPanel IsVisible="{Binding IsNewBook}" Margin="0,2,0,0">
                    <TextBlock DockPanel.Dock="Left"
                               Text="{x:Static res:Resources.MergeReview_Collection_Label}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <ComboBox ItemsSource="{Binding Collections}"
                              SelectedItem="{Binding SelectedCollection}"
                              DisplayMemberBinding="{Binding Name}"
                              FontSize="13"
                              MinWidth="220"
                              HorizontalAlignment="Left" />
                </DockPanel>
            </StackPanel>
        </Border>

        <!-- Book identity: always visible (title + ISBN) so the book under review is recognizable even when
             every source agrees and there are no diff rows to show. -->
        <Border DockPanel.Dock="Top" Margin="16,12,16,0">
            <StackPanel Spacing="2">
                <TextBlock Text="{Binding IdentityTitle}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding IdentityIsbnDisplay}"
                           IsVisible="{Binding HasIdentityIsbn}"
                           FontSize="12"
                           Opacity="0.7" />
            </StackPanel>
        </Border>

        <!-- Rate-limited sources banner: names sources dropped from this review because they returned 429,
             so the missing data reads as a known gap rather than a silent omission. -->
        <Border DockPanel.Dock="Top"
                IsVisible="{Binding HasRateLimitedNote}"
                Background="{DynamicResource BrushWarningBackground}"
                BorderBrush="{DynamicResource BrushWarning}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10,6"
                Margin="16,12,16,0">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="⚠" VerticalAlignment="Center"
                           Foreground="{DynamicResource BrushWarning}" />
                <TextBlock Text="{Binding RateLimitedNote}"
                           FontSize="12"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Errored sources banner: names sources that failed (non-429) and were skipped, so the gap reads
             as a known error rather than a silent omission. Styled as an error (red accent). -->
        <Border DockPanel.Dock="Top"
                IsVisible="{Binding HasErroredNote}"
                Background="{DynamicResource BrushWarningBackground}"
                BorderBrush="{DynamicResource BrushError}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10,6"
                Margin="16,8,16,0">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="⚠" VerticalAlignment="Center"
                           Foreground="{DynamicResource BrushError}" />
                <TextBlock Text="{Binding ErroredNote}"
                           FontSize="12"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- No-data note: names queried sources that had no record for this ISBN — a normal outcome, so it
             reads as neutral information (no colored background), not a warning. -->
        <Border DockPanel.Dock="Top"
                IsVisible="{Binding HasNoResultNote}"
                Padding="10,4"
                Margin="16,8,16,0">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="ℹ" VerticalAlignment="Center" Opacity="0.6" />
                <TextBlock Text="{Binding NoResultNote}"
                           FontSize="12"
                           Opacity="0.7"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Scrollable content -->
        <ScrollViewer Margin="16,12,16,8">
            <StackPanel>

                <!-- No conflicts message -->
                <TextBlock Text="{x:Static res:Resources.MergeReview_NoConflicts}"
                           FontSize="13"
                           IsVisible="{Binding HasNoConflicts}"
                           Margin="0,8" />

                <!-- Cover comparison row — one cell per AllColumnNames column, aligned to field rows. Always
                     shown (even with no metadata conflicts): sources can still offer different covers, and
                     hiding it would remove the cover choice entirely. -->
                <Border Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" MinWidth="150" />
                            <ColumnDefinition Width="*" MinWidth="150" />
                            <ColumnDefinition Width="*" MinWidth="150" />
                            <ColumnDefinition Width="*" MinWidth="150" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{x:Static res:Resources.Merge_Cover_Label}"
                                   FontWeight="SemiBold"
                                   FontSize="12"
                                   VerticalAlignment="Top"
                                   Margin="4,0,0,0" />
                        <ItemsControl Grid.Column="1" Grid.ColumnSpan="4"
                                      ItemsSource="{Binding CoverCells}"
                                      ToolTip.ShowDelay="400"
                                      ToolTip.BetweenShowDelay="0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:CoverCell">
                                    <StackPanel Spacing="2" Margin="4,0">
                                        <!-- A placeholder cell has a null Cover; routing the content through a
                                             ContentControl means its Cover-typed bindings never evaluate against
                                             null (which would log a binding error per property, per cell). -->
                                        <ContentControl Content="{Binding Cover}">
                                            <ContentControl.ContentTemplate>
                                                <DataTemplate x:DataType="vm:CoverOption">
                                                    <StackPanel Spacing="2">
                                                        <!-- Thumbnail with selection border and hover tooltip preview.
                                                             Disabled until the streamed cover has decoded — an empty
                                                             or still-loading slot must not be selectable. -->
                                                        <Button Width="80" Height="105"
                                                                HorizontalAlignment="Center"
                                                                CornerRadius="4"
                                                                Padding="0"
                                                                Background="Transparent"
                                                                IsEnabled="{Binding ThumbnailBitmap, Converter={x:Static ObjectConverters.IsNotNull}}"
                                                                Classes.selected="{Binding IsSelected}"
                                                                Command="{Binding $parent[ItemsControl].((vm:MergeReviewViewModel)DataContext).SelectCoverCommand}"
                                                                CommandParameter="{Binding}">
                                                            <Button.Styles>
                                                                <Style Selector="Button.selected">
                                                                    <Setter Property="BorderThickness" Value="2" />
                                                                    <Setter Property="BorderBrush" Value="DodgerBlue" />
                                                                </Style>
                                                                <Style Selector="Button.selected:pointerover /template/ ContentPresenter">
                                                                    <Setter Property="BorderThickness" Value="2" />
                                                                    <Setter Property="BorderBrush" Value="DodgerBlue" />
                                                                </Style>
                                                            </Button.Styles>
                                                            <ToolTip.Tip>
                                                                <ToolTip MaxWidth="420">
                                                                    <StackPanel Spacing="6" Margin="4">
                                                                        <Image Source="{Binding FullBitmap}"
                                                                               Stretch="Uniform"
                                                                               StretchDirection="DownOnly"
                                                                               RenderOptions.BitmapInterpolationMode = "HighQuality"
                                                                               MaxWidth="400"
                                                                               MaxHeight="560"
                                                                               IsVisible="{Binding FullBitmap, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                                                        <TextBlock Text="{Binding SourceName}"
                                                                                   FontWeight="SemiBold" />
                                                                        <TextBlock Text="{Binding CoverInfo}"
                                                                                   Opacity="0.7"
                                                                                   FontSize="11"
                                                                                   IsVisible="{Binding CoverInfo, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                                                    </StackPanel>
                                                                </ToolTip>
                                                            </ToolTip.Tip>
                                                            <Panel>
                                                                <Image Source="{Binding ThumbnailBitmap}" Stretch="Uniform" />
                                                                <ProgressBar IsIndeterminate="{Binding IsLoading}"
                                                                             IsVisible="{Binding IsLoading}"
                                                                             Width="56"
                                                                             HorizontalAlignment="Center"
                                                                             VerticalAlignment="Center" />
                                                            </Panel>
                                                        </Button>
                                                        <!-- Dimensions and file size below thumbnail -->
                                                        <TextBlock Text="{Binding CoverInfo}"
                                                                   FontSize="10"
                                                                   Opacity="0.6"
                                                                   HorizontalAlignment="Center"
                                                                   TextWrapping="NoWrap"
                                                                   IsVisible="{Binding CoverInfo, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ContentControl.ContentTemplate>
                                        </ContentControl>
                                        <!-- Placeholder to maintain column width when no cover -->
                                        <Border Width="80" Height="105"
                                                IsVisible="{Binding !HasCover}" />
                                        <!-- Column name label -->
                                        <TextBlock Text="{Binding ColumnName}"
                                                   FontSize="12"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,2,0,0"
                                                   IsVisible="{Binding HasCover}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <!-- Accept All buttons — aligned to source columns via same Grid+UniformGrid layout -->
                <Grid IsVisible="{Binding !HasNoConflicts}"
                      Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" MinWidth="150" />
                        <ColumnDefinition Width="*" MinWidth="150" />
                        <ColumnDefinition Width="*" MinWidth="150" />
                        <ColumnDefinition Width="*" MinWidth="150" />
                    </Grid.ColumnDefinitions>
                    <ItemsControl Grid.Column="1" Grid.ColumnSpan="4"
                                  ItemsSource="{Binding AllColumnNames}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Button Content="{Binding Converter={x:Static conv:AcceptAllLabelConverter.Instance}}"
                                        CommandParameter="{Binding}"
                                        Command="{Binding $parent[ItemsControl].((vm:MergeReviewViewModel)DataContext).AcceptAllFromSourceCommand}"
                                        Margin="4,0" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>

                <!-- Column headers — uses ItemsControl+UniformGrid bound to AllColumnNames so header
                     cells use the same layout math as data rows (also UniformGrid Rows="1"). -->
                <Grid IsVisible="{Binding !HasNoConflicts}"
                      Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" MinWidth="150" />
                        <ColumnDefinition Width="*" MinWidth="150" />
                        <ColumnDefinition Width="*" MinWidth="150" />
                        <ColumnDefinition Width="*" MinWidth="150" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{x:Static res:Resources.Merge_Column_Field}" FontSize="11" Opacity="0.6" Margin="4,0,0,2" />
                    <ItemsControl Grid.Column="1" Grid.ColumnSpan="4"
                                  ItemsSource="{Binding AllColumnNames}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <TextBlock Text="{Binding}" FontSize="11" FontWeight="SemiBold" Margin="4,0,0,2" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>

                <!-- Field diff rows — each FieldDiffRow.SourceValues is aligned to AllColumnNames -->
                <ItemsControl ItemsSource="{Binding FieldDiffs}"
                              IsVisible="{Binding !HasNoConflicts}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:FieldDiffRow">
                            <Border MinHeight="40"
                                    Padding="4,4"
                                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                    BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" MinWidth="150" />
                                        <ColumnDefinition Width="*" MinWidth="150" />
                                        <ColumnDefinition Width="*" MinWidth="150" />
                                        <ColumnDefinition Width="*" MinWidth="150" />
                                    </Grid.ColumnDefinitions>
                                    <!-- Field name -->
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding FieldName}"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               TextWrapping="Wrap" />
                                    <!-- Source value columns — rendered via ItemsControl over SourceValues
                                         which is padded to match AllColumnNames count -->
                                    <ItemsControl Grid.Column="1"
                                                  Grid.ColumnSpan="4"
                                                  ItemsSource="{Binding SourceValues}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Rows="1" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:SourceValueOption">
                                                <Panel Margin="4,0">
                                                    <!-- RadioButton shown when source has a value -->
                                                    <RadioButton IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                 Content="{Binding Value}"
                                                                 GroupName="{Binding $parent[Border].((vm:FieldDiffRow)DataContext).FieldName}"
                                                                 FontSize="12"
                                                                 IsVisible="{Binding Value, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                                 VerticalAlignment="Center" />
                                                    <!-- Placeholder when source has no value for this field -->
                                                    <TextBlock Text="—"
                                                               Opacity="0.35"
                                                               FontSize="12"
                                                               VerticalAlignment="Center"
                                                               IsVisible="{Binding Value, Converter={x:Static StringConverters.IsNullOrEmpty}}" />
                                                </Panel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
