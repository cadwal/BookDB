<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BookDB.Desktop.ViewModels"
             xmlns:res="using:BookDB.Desktop.Localization"
             x:Class="BookDB.Desktop.Views.ImportStepViews.ImportStep1View"
             x:DataType="vm:ImportStep1ViewModel">

    <StackPanel Margin="16" Spacing="12">

        <!-- File path section -->
        <TextBlock Text="{x:Static res:Resources.Import_Step1_FileLabel}" FontWeight="SemiBold"/>

        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto">
            <TextBox Grid.Column="0"
                     Text="{Binding FilePath, Mode=TwoWay}"
                     Watermark="{x:Static res:Resources.Import_Step1_FileWatermark}"
                     IsReadOnly="True"
                     Margin="0,0,8,0"/>
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="{x:Static res:Resources.Import_Step1_BrowseZip}"
                    Command="{Binding PickFileCommand}"/>
            <Button Content="{x:Static res:Resources.Import_Step1_BrowseFolder}"
                    Command="{Binding PickFolderCommand}"/>
        </StackPanel>

        <!-- Help text -->
        <TextBlock Text="{x:Static res:Resources.Import_Step1_HelpText}"
                   FontSize="11"
                   Opacity="0.6"
                   TextWrapping="Wrap"
                   Margin="0,8,0,0"/>

        <!-- Validation message -->
        <TextBlock Text="{Binding ErrorMessage}"
                   Foreground="{DynamicResource BrushError}"
                   FontSize="12"
                   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

        <!-- Collection selector -->
        <TextBlock Text="{x:Static res:Resources.Import_Step1_CollectionLabel}" FontWeight="SemiBold" Margin="0,8,0,0"/>

        <ComboBox ItemsSource="{Binding AvailableCollections}"
                  SelectedItem="{Binding SelectedCollection, Mode=TwoWay}"
                  PlaceholderText="{x:Static res:Resources.Import_Step1_CollectionWatermark}"
                  MinWidth="250">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Name}"/>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <!-- Create a new collection inline -->
        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto" MaxWidth="420" HorizontalAlignment="Left">
            <TextBox Grid.Column="0"
                     Text="{Binding NewCollectionName, Mode=TwoWay}"
                     Watermark="{x:Static res:Resources.Import_Step1_NewCollectionWatermark}"
                     MinWidth="250"
                     Margin="0,0,8,0"/>
            <Button Grid.Column="1"
                    Content="{x:Static res:Resources.Import_Step1_CreateCollection}"
                    Command="{Binding CreateCollectionCommand}"/>
        </Grid>

    </StackPanel>
</UserControl>
