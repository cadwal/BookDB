<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:BookDB.Desktop.ViewModels"
        xmlns:res="using:BookDB.Desktop.Localization"
        xmlns:i="using:Avalonia.Xaml.Interactivity"
        xmlns:behaviors="using:BookDB.Desktop.Behaviors"
        x:Class="BookDB.Desktop.Views.LookupWizardDialog"
        x:DataType="vm:LookupWizardViewModel"
        Title="{x:Static res:Resources.LookupWizard_Title}"
        Width="520"
        SizeToContent="Height"
        MinHeight="320"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <i:Interaction.Behaviors>
        <behaviors:TextFileDropBehavior
            AllowedExtensions=".txt,.csv"
            DropCommand="{Binding HandleFileDropCommand}" />
    </i:Interaction.Behaviors>

    <StackPanel Margin="24" Spacing="8">

        <!-- Header -->
        <TextBlock Text="{x:Static res:Resources.LookupWizard_Title}"
                   FontSize="16"
                   FontWeight="SemiBold" />

        <!-- ISBN multiline input -->
        <TextBox Name="IsbnTextBox"
                 AcceptsReturn="True"
                 MinLines="6"
                 FontFamily="Consolas, Courier New"
                 FontSize="13"
                 Watermark="{x:Static res:Resources.LookupWizard_IsbnBox_Placeholder}"
                 Text="{Binding IsbnText, Mode=TwoWay}"
                 AutomationProperties.Name="ISBN input - one per line" />

        <!-- ISBN count -->
        <TextBlock FontSize="12">
            <TextBlock.Text>
                <MultiBinding StringFormat="{x:Static res:Resources.LookupWizard_IsbnCount}">
                    <Binding Path="IsbnCount" />
                </MultiBinding>
            </TextBlock.Text>
        </TextBlock>

        <!-- Drop area -->
        <Border Name="DropBorder"
                Height="48"
                BorderThickness="1"
                CornerRadius="4">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="4">
                <TextBlock Text="{x:Static res:Resources.LookupWizard_DropArea_Label}"
                           VerticalAlignment="Center" />
                <Button Content="{x:Static res:Resources.LookupWizard_BrowseLink}"
                        Command="{Binding BrowseFileCommand}" />
            </StackPanel>
        </Border>

        <!-- Error panel -->
        <StackPanel IsVisible="{Binding ShowError}" Spacing="4">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}"
                       FontSize="13"
                       TextWrapping="Wrap" />
            <Button Content="{x:Static res:Resources.LookupWizard_ManualEntryButton}"
                    Command="{Binding ManualEntryCommand}" />
        </StackPanel>

        <!-- Busy indicator -->
        <StackPanel Orientation="Horizontal"
                    Spacing="8"
                    IsVisible="{Binding IsLookupRunning}"
                    HorizontalAlignment="Center">
            <ProgressBar IsIndeterminate="True"
                         Width="200"
                         Height="4" />
            <TextBlock Text="{x:Static res:Resources.LookupWizard_LookingUp}"
                       FontSize="12"
                       VerticalAlignment="Center" />
        </StackPanel>

        <!-- Footer buttons -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,8,0,0">
            <Button Content="{x:Static res:Resources.Common_Cancel}"
                    Command="{Binding CancelCommand}" />
            <Button Content="{x:Static res:Resources.LookupWizard_StartButton}"
                    Classes="accent"
                    Command="{Binding StartLookupCommand}"
                    IsEnabled="{Binding !IsLookupRunning}" />
        </StackPanel>

    </StackPanel>

</Window>
