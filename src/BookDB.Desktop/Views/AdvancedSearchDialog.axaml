<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:BookDB.Desktop.ViewModels"
        xmlns:res="using:BookDB.Desktop.Localization"
        x:Class="BookDB.Desktop.Views.AdvancedSearchDialog"
        x:DataType="vm:AdvancedSearchViewModel"
        Title="{Binding WindowTitle}"
        Width="620"
        Height="460"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False">
    <Grid RowDefinitions="Auto,*,Auto" Margin="24">

        <!-- Combinator selector -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
            <TextBlock Text="{x:Static res:Resources.AdvancedSearch_MatchLabel}" VerticalAlignment="Center" FontSize="13"/>
            <ComboBox ItemsSource="{Binding Combinators}"
                      SelectedItem="{Binding Combinator}"
                      MinWidth="80"
                      FontSize="13"/>
            <TextBlock Text="{x:Static res:Resources.AdvancedSearch_ConditionsLabel}" VerticalAlignment="Center" FontSize="13"/>
        </StackPanel>

        <!-- Condition rows -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="8">
                <ItemsControl ItemsSource="{Binding Conditions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:SearchConditionViewModel">
                            <Grid ColumnDefinitions="*,*,*,Auto" Margin="0,2">
                                <ComboBox Grid.Column="0"
                                          ItemsSource="{x:Static vm:SearchConditionViewModel.AvailableFields}"
                                          SelectedItem="{Binding SelectedField}"
                                          Margin="0,0,4,0"
                                          FontSize="13"/>
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{x:Static vm:SearchConditionViewModel.AvailableOperators}"
                                          SelectedItem="{Binding SelectedOperator}"
                                          Margin="0,0,4,0"
                                          FontSize="13"/>
                                <TextBox Grid.Column="2"
                                         Text="{Binding Value}"
                                         Margin="0,0,4,0"
                                         FontSize="13"/>
                                <Button Grid.Column="3"
                                        Content="x"
                                        FontSize="10"
                                        Command="{Binding $parent[ItemsControl].((vm:AdvancedSearchViewModel)DataContext).RemoveConditionCommand}"
                                        CommandParameter="{Binding}"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Add Condition button -->
                <Button Content="{x:Static res:Resources.AdvancedSearch_AddCondition}"
                        Command="{Binding AddConditionCommand}"
                        HorizontalAlignment="Left"
                        Margin="0,4,0,0"
                        FontSize="13"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Bottom section: Save as search + action buttons -->
        <StackPanel Grid.Row="2" Margin="0,16,0,0" Spacing="12">
            <Separator/>

            <!-- Save as named search row -->
            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Grid.Column="0"
                           Text="{x:Static res:Resources.AdvancedSearch_SaveSearch}"
                           VerticalAlignment="Center"
                           FontSize="13"
                           Margin="0,0,8,0"/>
                <TextBox Grid.Column="1"
                         Text="{Binding SavedSearchName}"
                         FontSize="13"
                         Margin="0,0,8,0"/>
                <Button Grid.Column="2"
                        Content="{x:Static res:Resources.Common_Save}"
                        Command="{Binding SaveSearchCommand}"
                        FontSize="13"/>
            </Grid>

            <!-- Test / Search / Cancel buttons -->
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="{Binding TestResultText}"
                           VerticalAlignment="Center"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                    <Button Content="{x:Static res:Resources.Common_Cancel}"
                            Command="{Binding CancelCommand}"
                            FontSize="13"/>
                    <Button Content="{x:Static res:Resources.AdvancedSearch_TestButton}"
                            Command="{Binding TestSearchCommand}"
                            FontSize="13"/>
                    <Button Content="{x:Static res:Resources.AdvancedSearch_SearchButton}"
                            Command="{Binding SearchCommand}"
                            FontSize="13"
                            IsDefault="True"
                            Classes="accent"/>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Grid>
</Window>
